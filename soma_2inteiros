#include <stdio.h>
int main(){
    int a,b;
 printf("Digite o primeiro valor: ");
 scanf("%d", &a);
 printf("Digite o segundo valor: ");
 scanf("%d", &b);
 int soma = (a + b);
 printf("primeiro valor: %d, segundo valor: %d\n" "resultado da soma: %d\n", a, b, soma);
 return(0);
}
